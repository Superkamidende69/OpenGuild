{
  "name": "openguild-desktop",
  "version": "0.1.0",
  "description": "A fully open-source Discord-like desktop community chat application foundation.",
  "private": true,
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "local-server": "node server/local-server.cjs",
    "dev": "concurrently -k \"node server/local-server.cjs\" \"vite --host 127.0.0.1\"",
    "desktop": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "package": "tsc --noEmit && vite build && electron-builder --dir"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.1.0",
    "electron": "^39.8.10",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "dev.openguild.desktop",
    "productName": "OpenGuild",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "server/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    }
  }
}
